{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python: Debug cli.py (Run)",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/Tool/Script/cli.py",
            "console": "integratedTerminal",
            "args": [
                "generate-data-pack-header",
                "--target-csv-path",
                "${workspaceFolder}/Resource",
                "--target-name",
                "Test",
                "--output-header-path",
                "${workspaceFolder}/DataPack/DataPack/Source/Inc",
                "--output-parser-path",
                "${workspaceFolder}/DataPack/DataChunkGenerator/Source/Inc",
                "--log-file-path",
                "${workspaceFolder}/Temp"
            ],
            "cwd": "${workspaceFolder}"
        }
    ]
}